# ==============================================================================
# Environment Configuration — EXAMPLE FILE
# ==============================================================================
# Copy this file to ".env" and fill in real values before running the app.
# NEVER commit the actual ".env" file to version control.
#   cp .env.example .env
# ==============================================================================

# --- Flask Core ---
# Leave SECRET_KEY blank in development to auto-generate one on first run,
# OR set a fixed 32+ character random string for production.
SECRET_KEY=

# Environment mode: development | production | testing
FLASK_ENV=development

# --- Database ---
# SQLite database filename. IMPORTANT: keep this as just a filename (no
# "instance/" prefix) — Flask-SQLAlchemy automatically resolves relative
# sqlite:/// URIs against the app's instance folder, so adding
# "instance/" here would incorrectly point to instance/instance/....
DATABASE_URL=sqlite:///log_management.db

# --- Security ---
# Minutes before a locked-out account can retry login
LOGIN_LOCKOUT_MINUTES=15
# Number of failed attempts before lockout
MAX_LOGIN_ATTEMPTS=5
# Session lifetime in minutes
SESSION_TIMEOUT_MINUTES=60

# --- Rate Limiting ---
RATELIMIT_STORAGE_URI=memory://

# --- Pagination / Export Limits ---
LOGS_PER_PAGE=25
MAX_EXPORT_ROWS=5000

# --- Simulated Log Generator ---
# Background thread: min/max seconds between auto-generated logs
LOG_GEN_INTERVAL_MIN=5
LOG_GEN_INTERVAL_MAX=15
# Enable/disable the background generator thread on startup
ENABLE_LOG_GENERATOR=true

# --- Admin Bootstrap Account (created on first seed if no admin exists) ---
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@secureops.local
ADMIN_PASSWORD=ChangeMe@123

# --- Caching ---
CACHE_TYPE=SimpleCache
CACHE_DEFAULT_TIMEOUT=60
