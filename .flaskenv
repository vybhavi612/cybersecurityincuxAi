# ==============================================================================
# Flask CLI Environment Variables
# ==============================================================================
# Automatically loaded by python-dotenv when using the `flask` CLI command.
# Lets you run the app with:  flask run
# (app.py also works directly with: python app.py)
# ==============================================================================

FLASK_APP=app.py
FLASK_DEBUG=1
FLASK_RUN_PORT=5000
FLASK_RUN_HOST=0.0.0.0
